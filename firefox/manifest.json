{
  "manifest_version": 3,
  "name": "PasteFox",
  "description": "Share code and text snippets to PasteFox with one click",
  "version": "1.0.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@pastefox.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://pastefox.com/*",
    "https://*.pastefox.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  }
}
